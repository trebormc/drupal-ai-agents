{
  "$schema": "https://opencode.ai/config.json",
  "model": "${MODEL_SMART}",
  "small_model": "${MODEL_CHEAP}",
  "autoupdate": true,
  "instructions": [
    "rules/beads-workflow.md",
    "rules/drupal-coding-standards.md",
    "rules/security-rules.md",
    "rules/ddev-environment.md",
    "rules/git-workflow.md",
    "rules/quality-tools-setup.md",
    "rules/lessons-learned.md"
  ],
  "permission": {
    "edit": "allow",
    "write": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "skill": {
      "*": "allow"
    },
    "bash": {
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "sudo *": "deny",
      "tail *": "allow",
      "git commit*": "deny",
      "git push*": "deny",
      "git pull*": "deny",
      "git add*": "deny",
      "git merge*": "deny",
      "git rebase*": "deny",
      "git checkout*": "deny",
      "git reset*": "deny",
      "git stash*": "deny",
      "git tag*": "deny",
      "docker *": "deny",
      "git diff*": "allow",
      "git log*": "allow",
      "git status*": "allow",
      "git branch*": "allow",
      "git show*": "allow",
      "*": "allow"
    }
  },
  "formatter": {
    "phpcbf": {
      "command": ["ssh", "web", "./vendor/bin/phpcbf", "--standard=Drupal,DrupalPractice", "$FILE"],
      "extensions": [".php", ".module", ".inc", ".install", ".theme", ".profile"]
    }
  },
  "mcp": {
    "playwright": {
      "type": "remote",
      "url": "http://playwright-mcp:8931/mcp",
      "enabled": true,
      "timeout": 30000
    }
  },
  "plugin": ["@mohak34/opencode-notifier@latest"]
}
